{
  "name": "superpower-agent",
  "version": "0.2.0",
  "description": "Adaptive PM->Build->QC->Ops agent system for Claude Code, OpenCode, Gemini CLI, Codex, Copilot, Cursor, Windsurf, and Antigravity.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nv-minh/superpower-agent.git"
  },
  "bugs": {
    "url": "https://github.com/nv-minh/superpower-agent/issues"
  },
  "homepage": "https://github.com/nv-minh/superpower-agent#readme",
  "author": "minh66hn",
  "type": "module",
  "bin": {
    "superpower-agent": "bin/superpower-agent.js"
  },
  "files": [
    "bin",
    "dist",
    "templates/base/CLAUDE.md",
    "templates/base/.claude/AGENTS.md",
    "templates/base/.claude/STRUCTURE.md",
    "templates/base/.claude/commands/*.md",
    "templates/base/.claude/commands/fad/**/*",
    "templates/base/.claude/commands/gsd/help.md",
    "templates/base/.claude/commands/gsd/map-codebase.md",
    "templates/base/.claude/commands/gsd/pr-branch.md",
    "templates/base/.claude/commands/gsd/ship.md",
    "templates/base/.claude/config/**/*",
    "templates/base/.claude/hooks/**/*",
    "templates/base/.claude/instructions/**/*",
    "templates/base/.claude/memory/**/*",
    "templates/base/.claude/package.json",
    "templates/base/.claude/pm/commands/README.md",
    "templates/base/.claude/pm/commands/discover.md",
    "templates/base/.claude/pm/commands/plan-roadmap.md",
    "templates/base/.claude/pm/commands/prioritize.md",
    "templates/base/.claude/pm/commands/strategy.md",
    "templates/base/.claude/pm/commands/write-prd.md",
    "templates/base/.claude/pm/skills/discovery-process/SKILL.md",
    "templates/base/.claude/pm/skills/epic-breakdown-advisor/SKILL.md",
    "templates/base/.claude/pm/skills/epic-hypothesis/SKILL.md",
    "templates/base/.claude/pm/skills/opportunity-solution-tree/SKILL.md",
    "templates/base/.claude/pm/skills/positioning-workshop/SKILL.md",
    "templates/base/.claude/pm/skills/prd-development/SKILL.md",
    "templates/base/.claude/pm/skills/prioritization-advisor/SKILL.md",
    "templates/base/.claude/pm/skills/problem-statement/SKILL.md",
    "templates/base/.claude/pm/skills/product-strategy-session/SKILL.md",
    "templates/base/.claude/pm/skills/roadmap-planning/SKILL.md",
    "templates/base/.claude/pm/skills/user-story/SKILL.md",
    "templates/base/.claude/pm/skills/user-story-mapping/SKILL.md",
    "templates/base/.claude/pm/skills/user-story-splitting/SKILL.md",
    "templates/base/.claude/rules/**/*",
    "templates/base/.claude/scripts/**/*",
    "templates/base/.claude/skills/**/*",
    "templates/base/.claude/state/**/*",
    "templates/base/.planning/**/*",
    "templates/base/docs/**/*",
    "templates/vendor/**/*",
    "docs/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "npm run build && node bin/superpower-agent.js --help",
    "test": "npm run build && node tests/smoke-init.test.mjs",
    "check": "npm run test && node dist/cli.js --help >/dev/null",
    "vendor:refresh": "node scripts/refresh-vendor-archives.mjs",
    "sync-template": "bash scripts/sync-template.sh",
    "export-standalone": "bash scripts/export-standalone-repo.sh"
  },
  "keywords": [
    "claude-code",
    "opencode",
    "gemini-cli",
    "agent",
    "workflow",
    "copilot",
    "pm",
    "tdd",
    "brownfield",
    "cursor",
    "windsurf",
    "antigravity",
    "qc",
    "ops"
  ],
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
